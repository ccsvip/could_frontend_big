        "required": [
          "text"
        ]
      },
      "DeviceSummary": {
        "type": "object",
        "nullable": true,
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string"
          },
          "recordId": {
            "type": "integer"
          },
          "deviceCode": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "description": "后台维护的设备名称，设备端只读使用。"
          },
          "status": {
            "type": "string",
            "enum": [
              "online",
              "offline"
            ]
          },
          "tenantId": {
            "type": "integer",
            "nullable": true
          },
          "tenantName": {
            "type": "string"
          },
          "applicationId": {
            "type": "integer",
            "nullable": true
          },
          "applicationName": {
            "type": "string"
          },
          "agentApplicationId": {
            "type": "integer",
            "nullable": true
          },
          "agentApplicationName": {
            "type": "string"
          },
          "authorizationType": {
            "type": "string",
            "enum": [
              "permanent",
              "trial"
            ]
          },
          "authorizationTypeLabel": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "isEnabled": {
            "type": "boolean"
          },
          "registeredAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "lastAuthAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "lastHeartbeat": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "ApplicationSummary": {
        "type": "object",
        "nullable": true,
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "code": {
            "type": "string"
          }
        }
      },
      "AgentApplicationSummary": {
        "type": "object",
        "nullable": true,
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "llmModelId": {
            "type": "integer",
            "nullable": true
          },
          "llmModelName": {
            "type": "string"
          }
        }
      },
      "RuntimeResources": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ResourceItem"
            }
          },
          "videos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ResourceItem"
            }
          },
          "scrollingTexts": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "voiceTones": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TtsVoice"
            }
          },
          "models": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ModelItem"
            }
          }
        }
      },
      "ResourceItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "category": {
            "type": "string"
          }
        }
      },
      "ModelItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "modelType": {
            "type": "string"
          },
          "orientation": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "thumbnailUrl": {
            "type": "string"
          }
        }
      },
      "TtsVoice": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "voiceCode": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "iconUrl": {
            "type": "string"
          },
          "avatarPath": {
            "type": "string"
          }
        }
      }
    }
  }
