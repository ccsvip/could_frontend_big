# .understandignore - patterns for files/dirs to exclude from analysis
# Syntax: same as .gitignore.
#
# Built-in defaults already exclude node_modules, .git, dist, build, lock files,
# minified assets, media files, and common caches. Project-specific runtime
# artifacts are listed below.

# Python / Django runtime artifacts
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
backend/media/
backend/staticfiles/
backend/celerybeat-schedule*
backend/*.sqlite3
backend/*.sqlite3-journal
backend/*-backup-*.json
backend/point-backup-*.json

# Frontend generated output and caches
web/dist/
web/build/
web/.vite/
web/node_modules/
*.tsbuildinfo
web/*.d.ts

# Local generated artifacts
output/
logs/
backend/logs/

# Local tooling state
.playwright-mcp
.understand-anything/intermediate/
.understand-anything/tmp/
.understand-anything/knowledge-graph.json
.understand-anything/fingerprints.json
.understand-anything/meta.json
