          "PermissionPoint",
          "Role",
          "UserRole"
        ],
        "businessRules": [
          "Tenant users must operate within an active tenant scope. Role and menu grants determine visible pages and write permissions. Account applications require review before activation."
        ],
        "crossDomainInteractions": [
          "Permissions gate device, resource, AI, and audit operations. Tenant scope filters most business data."
        ]
      }
    },
    {
